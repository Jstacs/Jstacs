				<exclude name="**/*.gff" />
				<exclude name="**/*.bam" />
				<exclude name="**/*.hprof" />
			</fileset>

			<zipfileset excludes="META-INF/*.SF" src="${dir.buildfile}/lib/htsjdk-2.5.0-4-gd683012-SNAPSHOT.jar"/>
			<zipfileset excludes="META-INF/*.SF" src="${dir.buildfile}/lib/graaljs/chromeinspector.jar"/>
